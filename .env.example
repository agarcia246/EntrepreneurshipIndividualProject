# Supabase project credentials (get from https://supabase.com/dashboard → Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Vite base path — set to "/" for local dev, "/EntrepreneurshipIndividualProject/" for GitHub Pages
# Omit or leave blank to use the default (/EntrepreneurshipIndividualProject/)
# VITE_BASE_PATH=/
